# ================================== Redis Module 配置 ==================================
- module: redis

  # ================================== Log 配置 ==================================
  log:
    enabled: {{ log_enabled | default(true) | lower }}
    {% if log_paths %}
    var.paths:
      {% for path in log_paths %}
      - "{{ path }}"
      {% endfor %}
    {% endif %}
    input:
      fields:
        collector: "Filebeat"
        collect_type: "redis"
        instance_id: "{{ instance_id }}"
      fields_under_root: {{ fields_under_root | default(true) | lower }}

  # ================================== Slowlog 配置 ==================================
  slowlog:
    enabled: {{ slowlog_enabled | default(false) | lower }}
    {% if slowlog_hosts %}
    var.hosts:
      {% for host in slowlog_hosts %}
      - "{{ host }}"
      {% endfor %}
    {% endif %}
    {% if slowlog_password %}
    var.password: "{{ slowlog_password }}"
    {% endif %}
    input:
      fields:
        collector: "Filebeat"
        collect_type: "redis"
        instance_id: "{{ instance_id }}"
      fields_under_root: {{ fields_under_root | default(true) | lower }}
