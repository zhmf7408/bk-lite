{
  "name": "elasticsearch",
  "collector": "Filebeat",
  "config_section": "module",
  "icon": "mm-elasticsearch_Elasticsearch",
  "description": "Collects and parses Elasticsearch server, audit, slowlog, deprecation and GC logs using Filebeat module",
  "default_query": "collect_type: elasticsearch | last 1 by (_time) partition by (instance_id)",
  "attrs": [
    "collect_type",
    "collector",
    "instance_id",
    "elasticsearch.server.message",
    "elasticsearch.server.level",
    "elasticsearch.server.component",
    "elasticsearch.server.node.name",
    "elasticsearch.server.cluster.name",
    "elasticsearch.audit.event_type",
    "elasticsearch.audit.origin.type",
    "elasticsearch.audit.user.name",
    "elasticsearch.audit.request.name",
    "elasticsearch.slowlog.type",
    "elasticsearch.slowlog.source",
    "elasticsearch.slowlog.took",
    "elasticsearch.slowlog.index",
    "elasticsearch.deprecation.message",
    "elasticsearch.deprecation.level",
    "elasticsearch.gc.heap.size_kb",
    "elasticsearch.gc.young.pause_time.ms",
    "elasticsearch.gc.old.pause_time.ms",
    "event.dataset",
    "event.module",
    "fileset.name"
  ],
  "display_category": "database"
}