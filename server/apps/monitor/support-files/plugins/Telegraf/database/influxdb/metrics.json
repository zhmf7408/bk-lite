{
  "plugin": "InfluxDB",
  "plugin_desc": "由 Telegraf 采集器通过 InfluxDB v1 的 /debug/vars 接口采集关键指标，重点关注序列规模、HTTP 服务质量、写入异常、查询压力和运行时内存。",
  "status_query": "any({instance_type='influxdb', collect_type='database'}) by (host, instance_role)",
  "name": "InfluxDB",
  "icon": "mm-db_数据库",
  "type": "Database",
  "description": "",
  "default_metric": "any({instance_type='influxdb'}) by (instance_id)",
  "instance_id_keys": ["instance_id"],
  "supplementary_indicators": [
    "influxdb_database_numSeries",
"influxdb_httpd_写请求速率",
    "influxdb_runtime_HeapAlloc"
  ],
  "metrics": [
    {
      "metric_group": "数据库",
      "name": "influxdb_database_numSeries",
      "display_name": "序列数",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [
        {
          "name": "database",
          "description": "Database name"
        }
      ],
      "description": "Number of series in a single InfluxDB database. This is the most important cardinality control indicator.",
      "query": "influxdb_database_numSeries{__$labels__}"
    },
    {
      "metric_group": "HTTPD",
      "name": "influxdb_httpd_authFail_rate",
      "display_name": "HTTP 认证失败速率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cpm",
      "dimensions": [
        {
          "name": "bind",
          "description": "Bind address"
        }
      ],
      "description": "Authentication failure count per minute on the HTTP endpoint.",
      "query": "sum(increase(influxdb_httpd_authFail{__$labels__}[1m])) by (instance_id, bind)"
    },
    {
      "metric_group": "HTTPD",
      "name": "influxdb_httpd_clientError_rate",
      "display_name": "HTTP 4XX 错误速率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cpm",
      "dimensions": [
        {
          "name": "bind",
          "description": "Bind address"
        }
      ],
      "description": "4XX client error responses per minute on the HTTP endpoint.",
      "query": "sum(increase(influxdb_httpd_clientError{__$labels__}[1m])) by (instance_id, bind)"
    },
    {
      "metric_group": "HTTPD",
      "name": "influxdb_httpd_serverError_rate",
      "display_name": "HTTP 5XX 错误速率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cpm",
      "dimensions": [
        {
          "name": "bind",
          "description": "Bind address"
        }
      ],
      "description": "5XX server error responses per minute on the HTTP endpoint.",
      "query": "sum(increase(influxdb_httpd_serverError{__$labels__}[1m])) by (instance_id, bind)"
    },
    {
      "metric_group": "HTTPD",
      "name": "influxdb_httpd_pointsWrittenDropped_rate",
      "display_name": "写点丢弃速率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cpm",
      "dimensions": [
        {
          "name": "bind",
          "description": "Bind address"
        }
      ],
      "description": "Number of points accepted by the write API but dropped before persistence per minute.",
      "query": "sum(increase(influxdb_httpd_pointsWrittenDropped{__$labels__}[1m])) by (instance_id, bind)"
    },
    {
      "metric_group": "HTTPD",
      "name": "influxdb_httpd_pointsWrittenFail_rate",
      "display_name": "写入持久化失败速率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cpm",
      "dimensions": [
        {
          "name": "bind",
          "description": "Bind address"
        }
      ],
      "description": "Number of points accepted by the write API but failed to persist per minute.",
      "query": "sum(increase(influxdb_httpd_pointsWrittenFail{__$labels__}[1m])) by (instance_id, bind)"
    },
    {
      "metric_group": "HTTPD",
      "name": "influxdb_httpd_writeReq_rate",
      "display_name": "写入请求速率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [
        {
          "name": "bind",
          "description": "Bind address"
        }
      ],
      "description": "Write request rate over the last 5 minutes.",
      "query": "sum(rate(influxdb_httpd_writeReq{__$labels__}[5m])) by (instance_id, bind)"
    },
    {
      "metric_group": "HTTPD",
      "name": "influxdb_httpd_queryReq_rate",
      "display_name": "查询请求速率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [
        {
          "name": "bind",
          "description": "Bind address"
        }
      ],
      "description": "Query request rate over the last 5 minutes.",
      "query": "sum(rate(influxdb_httpd_queryReq{__$labels__}[5m])) by (instance_id, bind)"
    },
    {
      "metric_group": "运行时",
      "name": "influxdb_runtime_HeapAlloc",
      "display_name": "运行时堆内存分配",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "description": "Bytes allocated and currently in use in the Go heap.",
      "query": "influxdb_runtime_HeapAlloc{__$labels__}"
    }
  ]
}
