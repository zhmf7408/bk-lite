{
  "object": "Etcd",
  "plugin": "Etcd",
  "templates": [
    {
      "name": "Etcd 集群无 Leader",
      "alert_name": "Etcd ${resource_name} 集群无Leader",
      "description": "检测 etcd 是否存在 leader，返回 0 表示当前成员无法观察到 leader，集群可能不可写或处于异常选主状态。",
      "metric_name": "etcd_server_has_leader_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 1,
          "method": "!="
        }
      ]
    },
    {
      "name": "Etcd Leader 切换频繁",
      "alert_name": "Etcd ${resource_name} Leader 频繁切换",
      "description": "监控 5 分钟内 leader 切换速率，频繁切换通常意味着网络抖动、时钟漂移或节点负载异常。",
      "metric_name": "etcd_server_leader_changes_seen_total_counter_rate",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 0.1,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 0.03,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd 心跳发送失败",
      "alert_name": "Etcd ${resource_name} 心跳发送失败率升高",
      "description": "监控 leader 心跳发送失败速率，持续升高通常表示节点间网络或 peer 连接存在异常。",
      "metric_name": "etcd_server_heartbeat_send_failures_total_counter_rate",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 0.1,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 0.01,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd Backend 配额使用率过高",
      "alert_name": "Etcd ${resource_name} Backend 配额使用率过高",
      "description": "监控 backend 已分配空间占配额的比例，长期偏高会触发 quota 限制并影响写入。",
      "metric_name": "etcd_backend_allocated_usage_percent",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 80,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd Backend 急需整理",
      "alert_name": "Etcd ${resource_name} Backend 急需整理",
      "description": "当 backend 已分配空间达到紧急阈值时触发，提示尽快执行 compact 或 defrag，避免配额耗尽。",
      "metric_name": "etcd_backend_urgent_defrag",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 1,
          "method": "=="
        }
      ]
    },
    {
      "name": "Etcd Backend 碎片率过高",
      "alert_name": "Etcd ${resource_name} Backend 碎片率过高",
      "description": "监控 backend 分配大小与实际使用大小的差异，碎片率过高会浪费存储并放大 defrag 需求。",
      "metric_name": "etcd_backend_fragmentation_percent",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 50,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 30,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd WAL fsync 延迟过高",
      "alert_name": "Etcd ${resource_name} WAL fsync P99 过高",
      "description": "监控 WAL fsync 的 P99 延迟，持续升高说明磁盘刷盘性能正在影响写入路径。",
      "metric_name": "etcd_disk_wal_fsync_p99_seconds",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 0.05,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 0.02,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd Backend Commit 延迟过高",
      "alert_name": "Etcd ${resource_name} Backend Commit P99 过高",
      "description": "监控 backend commit 的 P99 延迟，持续升高通常表示 BoltDB 提交或底层磁盘性能出现瓶颈。",
      "metric_name": "etcd_disk_backend_commit_p99_seconds",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 0.1,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 0.05,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd 提案失败率过高",
      "alert_name": "Etcd ${resource_name} 提案失败率过高",
      "description": "监控 raft proposal 失败速率，持续升高说明一致性提交链路存在异常。",
      "metric_name": "etcd_server_proposals_failed_total_counter_rate",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 1,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 0.1,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd 提案排队积压",
      "alert_name": "Etcd ${resource_name} 提案排队积压",
      "description": "监控 proposals pending，持续积压意味着提案无法及时提交，可能由 leader 负载、磁盘或网络问题导致。",
      "metric_name": "etcd_server_proposals_pending_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 32,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 8,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd 提案应用落后",
      "alert_name": "Etcd ${resource_name} 提案应用落后",
      "description": "监控 committed 与 applied proposals 的差值，持续扩大说明状态机应用速度跟不上提交速度。",
      "metric_name": "etcd_server_proposals_apply_lag",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 128,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 32,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd 慢应用请求增多",
      "alert_name": "Etcd ${resource_name} 慢应用请求增多",
      "description": "监控 slow apply 请求速率，升高说明状态机应用路径已经出现明显性能退化。",
      "metric_name": "etcd_server_slow_apply_total_counter_rate",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 1,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 0.1,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd 慢读索引增多",
      "alert_name": "Etcd ${resource_name} 慢读索引增多",
      "description": "监控 slow read index 请求速率，升高通常表示 quorum 读路径受网络或 leader 压力影响。",
      "metric_name": "etcd_server_slow_read_indexes_total_counter_rate",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 1,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 0.1,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd Read Index 失败",
      "alert_name": "Etcd ${resource_name} Read Index 失败率升高",
      "description": "监控 read index 失败速率，升高说明线性一致性读路径存在异常。",
      "metric_name": "etcd_server_read_indexes_failed_total_counter_rate",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 0.1,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 0.01,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd Peer 发送失败",
      "alert_name": "Etcd ${resource_name} Peer 发送失败率升高",
      "description": "监控 peer 发送失败速率，持续非零通常意味着节点间复制链路存在网络或连接异常。",
      "metric_name": "etcd_network_peer_sent_failures_total_counter_rate",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 0.1,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 0.01,
          "method": ">="
        }
      ]
    },
    {
      "name": "Etcd RPC 失败率过高",
      "alert_name": "Etcd ${resource_name} RPC 失败率过高",
      "description": "监控非 OK 的 unary RPC 失败速率，升高表示客户端访问路径已经出现明显错误。",
      "metric_name": "etcd_rpc_failed_rate",
      "algorithm": "avg",
      "threshold": [
        {
          "level": "critical",
          "value": 5,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 1,
          "method": ">="
        }
      ]
    }
  ]
}
