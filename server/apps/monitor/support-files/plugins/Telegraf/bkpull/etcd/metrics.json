{
  "plugin": "Etcd",
  "plugin_desc": "由 Telegraf Pull 采集器通过 Prometheus 指标端点采集 etcd 关键监控指标，覆盖集群状态、存储容量、磁盘时延、一致性提案、请求流量以及监听压缩等核心运维场景。",
  "status_query": "any({instance_type='etcd', collect_type='bkpull'}) by (instance_id)",
  "name": "Etcd",
  "icon": "mm-middleware_中间件",
  "type": "Middleware",
  "description": "",
  "default_metric": "any({instance_type='etcd'}) by (instance_id)",
  "instance_id_keys": ["instance_id"],
  "supplementary_indicators": [
    "etcd_server_has_leader_gauge",
    "etcd_backend_allocated_usage_percent",
    "etcd_backend_urgent_defrag",
    "etcd_server_proposals_pending_gauge",
    "etcd_server_proposals_apply_lag",
    "etcd_disk_wal_fsync_p99_seconds"
  ],
  "metrics": [
    {
      "metric_group": "集群状态",
      "name": "etcd_server_has_leader_gauge",
      "display_name": "集群是否有主节点",
      "instance_id_keys": ["instance_id"],
      "data_type": "Enum",
      "unit": "[{\"name\":\"无主节点\",\"id\":0,\"color\":\"#ff4d4f\"},{\"name\":\"有主节点\",\"id\":1,\"color\":\"#1ac44a\"}]",
      "dimensions": [],
      "description": "当前成员是否能感知到集群主节点。",
      "query": "etcd_server_has_leader_gauge{__$labels__}"
    },
    {
      "metric_group": "集群状态",
      "name": "etcd_server_is_leader_gauge",
      "display_name": "当前角色",
      "instance_id_keys": ["instance_id"],
      "data_type": "Enum",
      "unit": "[{\"name\":\"从节点\",\"id\":0,\"color\":\"#8c8c8c\"},{\"name\":\"主节点\",\"id\":1,\"color\":\"#1ac44a\"}]",
      "dimensions": [],
      "description": "当前成员在集群中的角色。",
      "query": "etcd_server_is_leader_gauge{__$labels__}"
    },
    {
      "metric_group": "集群状态",
      "name": "etcd_network_active_peers_gauge",
      "display_name": "活跃节点连接数",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "当前可用的节点间连接数。",
      "query": "sum(etcd_network_active_peers_gauge{__$labels__}) by (instance_id)"
    },
    {
      "metric_group": "集群状态",
      "name": "etcd_server_leader_changes_seen_total_counter_rate",
      "display_name": "主节点切换频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟主节点切换频率。",
      "query": "rate(etcd_server_leader_changes_seen_total_counter{__$labels__}[5m])"
    },
    {
      "metric_group": "集群状态",
      "name": "etcd_server_heartbeat_send_failures_total_counter_rate",
      "display_name": "心跳发送失败频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟心跳发送失败频率。",
      "query": "rate(etcd_server_heartbeat_send_failures_total_counter{__$labels__}[5m])"
    },
    {
      "metric_group": "集群状态",
      "name": "etcd_server_health_failures_counter_rate",
      "display_name": "健康检查失败频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟健康检查失败频率。",
      "query": "rate(etcd_server_health_failures_counter{__$labels__}[5m])"
    },
    {
      "metric_group": "存储与碎片",
      "name": "etcd_mvcc_db_total_size_in_bytes_gauge",
      "display_name": "后端已分配空间",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "description": "etcd 后端存储当前已分配的物理空间。",
      "query": "etcd_mvcc_db_total_size_in_bytes_gauge{__$labels__}"
    },
    {
      "metric_group": "存储与碎片",
      "name": "etcd_mvcc_db_total_size_in_use_in_bytes_gauge",
      "display_name": "后端实际使用空间",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "description": "etcd 后端存储当前实际使用的逻辑空间。",
      "query": "etcd_mvcc_db_total_size_in_use_in_bytes_gauge{__$labels__}"
    },
    {
      "metric_group": "存储与碎片",
      "name": "etcd_server_quota_backend_bytes_gauge",
      "display_name": "后端存储配额",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "description": "后端存储配置的容量上限。",
      "query": "etcd_server_quota_backend_bytes_gauge{__$labels__}"
    },
    {
      "metric_group": "存储与碎片",
      "name": "etcd_backend_allocated_usage_percent",
      "display_name": "后端存储使用率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "后端已分配空间占总配额的比例。",
      "query": "clamp_min(etcd_mvcc_db_total_size_in_bytes_gauge{__$labels__} / etcd_server_quota_backend_bytes_gauge{__$labels__} * 100, 0)"
    },
    {
      "metric_group": "存储与碎片",
      "name": "etcd_backend_remaining_bytes",
      "display_name": "后端剩余容量",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "description": "后端存储距离配额上限还剩多少空间。",
      "query": "clamp_min(etcd_server_quota_backend_bytes_gauge{__$labels__} - etcd_mvcc_db_total_size_in_bytes_gauge{__$labels__}, 0)"
    },
    {
      "metric_group": "存储与碎片",
      "name": "etcd_backend_fragmentation_percent",
      "display_name": "后端碎片率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "后端已分配空间与实际使用空间之间的碎片比例。",
      "query": "clamp_min((etcd_mvcc_db_total_size_in_bytes_gauge{__$labels__} - etcd_mvcc_db_total_size_in_use_in_bytes_gauge{__$labels__}) / clamp_min(etcd_mvcc_db_total_size_in_bytes_gauge{__$labels__}, 1) * 100, 0)"
    },
    {
      "metric_group": "存储与碎片",
      "name": "etcd_backend_urgent_defrag",
      "display_name": "是否需要整理碎片",
      "instance_id_keys": ["instance_id"],
      "data_type": "Enum",
      "unit": "[{\"name\":\"否\",\"id\":0,\"color\":\"#1ac44a\"},{\"name\":\"是\",\"id\":1,\"color\":\"#ff4d4f\"}]",
      "dimensions": [],
      "description": "当前后端空间是否已经达到需要尽快整理碎片的阈值。",
      "query": "((etcd_mvcc_db_total_size_in_bytes_gauge{__$labels__} / etcd_server_quota_backend_bytes_gauge{__$labels__} * 100) >= bool 80)"
    },
    {
      "metric_group": "存储与碎片",
      "name": "etcd_debugging_mvcc_keys_total_gauge",
      "display_name": "键数量",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "当前存储中的键总数。",
      "query": "etcd_debugging_mvcc_keys_total_gauge{__$labels__}"
    },
    {
      "metric_group": "存储与碎片",
      "name": "process_resident_memory_bytes_gauge",
      "display_name": "进程常驻内存",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "description": "etcd 进程当前占用的常驻内存。",
      "query": "process_resident_memory_bytes_gauge{instance_type=\"etcd\", __$labels__}"
    },
    {
      "metric_group": "磁盘时延",
      "name": "etcd_disk_wal_fsync_p99_seconds",
      "display_name": "WAL 刷盘延迟 P99",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "s",
      "dimensions": [],
      "description": "最近 5 分钟 WAL 刷盘延迟的 P99。",
      "query": "histogram_quantile(0.99, sum(rate((label_replace({__name__=~\"etcd_disk_wal_fsync_duration_seconds_[0-9.]+\", __$labels__}, \"le\", \"$1\", \"__name__\", \"etcd_disk_wal_fsync_duration_seconds_(.+)\"))[5m:]) or label_replace(rate(etcd_disk_wal_fsync_duration_seconds_count{__$labels__}[5m]), \"le\", \"+Inf\", \"__name__\", \".*\")) by (instance_id, le))"
    },
    {
      "metric_group": "磁盘时延",
      "name": "etcd_disk_backend_commit_p99_seconds",
      "display_name": "后端提交延迟 P99",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "s",
      "dimensions": [],
      "description": "最近 5 分钟后端提交延迟的 P99。",
      "query": "histogram_quantile(0.99, sum(rate((label_replace({__name__=~\"etcd_disk_backend_commit_duration_seconds_[0-9.]+\", __$labels__}, \"le\", \"$1\", \"__name__\", \"etcd_disk_backend_commit_duration_seconds_(.+)\"))[5m:]) or label_replace(rate(etcd_disk_backend_commit_duration_seconds_count{__$labels__}[5m]), \"le\", \"+Inf\", \"__name__\", \".*\")) by (instance_id, le))"
    },
    {
      "metric_group": "磁盘时延",
      "name": "etcd_debugging_snap_save_total_avg_seconds",
      "display_name": "快照平均耗时",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "s",
      "dimensions": [],
      "description": "最近 5 分钟快照保存的平均耗时。",
      "query": "sum(rate(etcd_debugging_snap_save_total_duration_seconds_sum{__$labels__}[5m])) by (instance_id) / clamp_min(sum(rate(etcd_debugging_snap_save_total_duration_seconds_count{__$labels__}[5m])) by (instance_id), 1e-9)"
    },
    {
      "metric_group": "提案与一致性",
      "name": "etcd_server_proposals_pending_gauge",
      "display_name": "提案积压数",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "当前等待提交的提案数量。",
      "query": "etcd_server_proposals_pending_gauge{__$labels__}"
    },
    {
      "metric_group": "提案与一致性",
      "name": "etcd_server_proposals_failed_total_counter_rate",
      "display_name": "提案失败频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟提案失败频率。",
      "query": "rate(etcd_server_proposals_failed_total_counter{__$labels__}[5m])"
    },
    {
      "metric_group": "提案与一致性",
      "name": "etcd_server_proposals_committed_rate",
      "display_name": "提案提交频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟提案提交频率。",
      "query": "rate(etcd_server_proposals_committed_total_gauge{__$labels__}[5m])"
    },
    {
      "metric_group": "提案与一致性",
      "name": "etcd_server_proposals_applied_rate",
      "display_name": "提案应用频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟提案应用频率。",
      "query": "rate(etcd_server_proposals_applied_total_gauge{__$labels__}[5m])"
    },
    {
      "metric_group": "提案与一致性",
      "name": "etcd_server_proposals_apply_lag",
      "display_name": "提案应用落后数",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "已提交提案与已应用提案之间的差值。",
      "query": "clamp_min(etcd_server_proposals_committed_total_gauge{__$labels__} - etcd_server_proposals_applied_total_gauge{__$labels__}, 0)"
    },
    {
      "metric_group": "提案与一致性",
      "name": "etcd_server_slow_apply_total_counter_rate",
      "display_name": "慢应用请求频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟慢应用请求频率。",
      "query": "rate(etcd_server_slow_apply_total_counter{__$labels__}[5m])"
    },
    {
      "metric_group": "提案与一致性",
      "name": "etcd_server_read_indexes_failed_total_counter_rate",
      "display_name": "读索引失败频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟读索引失败频率。",
      "query": "rate(etcd_server_read_indexes_failed_total_counter{__$labels__}[5m])"
    },
    {
      "metric_group": "提案与一致性",
      "name": "etcd_server_slow_read_indexes_total_counter_rate",
      "display_name": "慢读索引频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟慢读索引请求频率。",
      "query": "rate(etcd_server_slow_read_indexes_total_counter{__$labels__}[5m])"
    },
    {
      "metric_group": "请求与流量",
      "name": "etcd_server_client_requests_total_counter_rate",
      "display_name": "客户端请求频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟 etcd 处理的客户端请求频率。",
      "query": "sum(rate(etcd_server_client_requests_total_counter{__$labels__}[5m])) by (instance_id)"
    },
    {
      "metric_group": "请求与流量",
      "name": "etcd_rpc_rate",
      "display_name": "RPC 请求频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟一元 RPC 请求频率。",
      "query": "sum(rate(grpc_server_started_total_counter{grpc_type=\"unary\", instance_type=\"etcd\", __$labels__}[5m])) by (instance_id)"
    },
    {
      "metric_group": "请求与流量",
      "name": "etcd_rpc_failed_rate",
      "display_name": "RPC 失败频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟非 OK 的一元 RPC 失败频率。",
      "query": "sum(rate(grpc_server_handled_total_counter{grpc_type=\"unary\", grpc_code!=\"OK\", instance_type=\"etcd\", __$labels__}[5m])) by (instance_id)"
    },
    {
      "metric_group": "请求与流量",
      "name": "etcd_network_client_grpc_received_bytes_total_counter_rate",
      "display_name": "客户端入站流量",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "byteps",
      "dimensions": [],
      "description": "最近 5 分钟来自客户端 gRPC 请求的入站流量。",
      "query": "sum(rate(etcd_network_client_grpc_received_bytes_total_counter{__$labels__}[5m])) by (instance_id)"
    },
    {
      "metric_group": "请求与流量",
      "name": "etcd_network_client_grpc_sent_bytes_total_counter_rate",
      "display_name": "客户端出站流量",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "byteps",
      "dimensions": [],
      "description": "最近 5 分钟发送给客户端 gRPC 请求的出站流量。",
      "query": "sum(rate(etcd_network_client_grpc_sent_bytes_total_counter{__$labels__}[5m])) by (instance_id)"
    },
    {
      "metric_group": "请求与流量",
      "name": "etcd_network_peer_received_bytes_total_counter_rate",
      "display_name": "节点间入站流量",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "byteps",
      "dimensions": [],
      "description": "最近 5 分钟来自对等节点的入站流量。",
      "query": "sum(rate(etcd_network_peer_received_bytes_total_counter{__$labels__}[5m])) by (instance_id)"
    },
    {
      "metric_group": "请求与流量",
      "name": "etcd_network_peer_sent_bytes_total_counter_rate",
      "display_name": "节点间出站流量",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "byteps",
      "dimensions": [],
      "description": "最近 5 分钟发送给对等节点的出站流量。",
      "query": "sum(rate(etcd_network_peer_sent_bytes_total_counter{__$labels__}[5m])) by (instance_id)"
    },
    {
      "metric_group": "请求与流量",
      "name": "etcd_network_peer_sent_failures_total_counter_rate",
      "display_name": "节点间发送失败频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟节点间发送失败频率。",
      "query": "sum(rate(etcd_network_peer_sent_failures_total_counter{__$labels__}[5m])) by (instance_id)"
    },
    {
      "metric_group": "监听与压缩",
      "name": "etcd_debugging_mvcc_watcher_total_gauge",
      "display_name": "监听器数量",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "当前监听器数量。",
      "query": "etcd_debugging_mvcc_watcher_total_gauge{__$labels__}"
    },
    {
      "metric_group": "监听与压缩",
      "name": "etcd_watch_streams_active",
      "display_name": "活跃监听流",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "根据已建立和已结束的流式 RPC 推算出的当前活跃监听流数量。",
      "query": "sum(grpc_server_started_total_counter{grpc_service=\"etcdserverpb.Watch\", grpc_type=\"bidi_stream\", instance_type=\"etcd\", __$labels__}) by (instance_id) - sum(grpc_server_handled_total_counter{grpc_service=\"etcdserverpb.Watch\", grpc_type=\"bidi_stream\", instance_type=\"etcd\", __$labels__}) by (instance_id)"
    },
    {
      "metric_group": "监听与压缩",
      "name": "etcd_debugging_mvcc_db_compaction_keys_total_counter_rate",
      "display_name": "压缩键处理频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟压缩处理的键数量频率。",
      "query": "rate(etcd_debugging_mvcc_db_compaction_keys_total_counter{__$labels__}[5m])"
    },
    {
      "metric_group": "监听与压缩",
      "name": "etcd_mvcc_put_total_counter_rate",
      "display_name": "写入频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟写入操作频率。",
      "query": "rate(etcd_mvcc_put_total_counter{__$labels__}[5m])"
    },
    {
      "metric_group": "监听与压缩",
      "name": "etcd_mvcc_delete_total_counter_rate",
      "display_name": "删除频率",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "最近 5 分钟删除操作频率。",
      "query": "rate(etcd_mvcc_delete_total_counter{__$labels__}[5m])"
    }
  ]
}
