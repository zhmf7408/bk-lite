[[inputs.prometheus]]
    startup_error_behavior = "retry"
    urls = [
        "{{ scheme | default('http') }}://{{ host }}:{{ port }}{{ metrics_path | default('/metrics') }}",
    ]
    interval = "{{ interval }}s"
    timeout = "30s"
    response_timeout = "30s"
    {% if tls_ca %}
    tls_ca = "{{ tls_ca }}"
    {% endif %}
    {% if tls_cert %}
    tls_cert = "{{ tls_cert }}"
    {% endif %}
    {% if tls_key %}
    tls_key = "{{ tls_key }}"
    {% endif %}
    insecure_skip_verify = {{ insecure_skip_verify | default(false) | lower }}
    [inputs.prometheus.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "bkpull"
        config_type = "etcd"
