FROM python:3.12

WORKDIR /apps

RUN apt-get update -y && \
    apt-get upgrade -y && \
    apt-get install -y vim supervisor && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install browser-use/patchright dependencies: system libraries and fonts for headless Chromium
RUN apt-get update -y && \
    apt-get install -y --no-install-recommends \
        fonts-unifont \
        fonts-liberation \
        fonts-dejavu-core \
        fonts-freefont-ttf \
        fonts-noto-core \
        libnss3 \
        libxss1 \
        libasound2 \
        libx11-xcb1 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libcups2 \
        libdrm2 \
        libxkbcommon0 \
        libxcomposite1 \
        libxdamage1 \
        libxrandr2 \
        libgbm1 \
        libpango-1.0-0 \
        libcairo2 \
        libxshmfence1 \
        libxfixes3 \
        libglu1-mesa && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install Microsoft ODBC Driver 18 for SQL Server (required for pyodbc compilation)
# Installation may fail in restricted networks, but won't block the build
RUN curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft-prod.gpg && \
    curl -fsSL https://packages.microsoft.com/config/debian/12/prod.list | tee /etc/apt/sources.list.d/mssql-release.list && \
    apt-get update && \
    ACCEPT_EULA=Y apt-get install -y msodbcsql18 unixodbc-dev && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* || \
    echo "Warning: MSSQL ODBC driver installation failed, MSSQL tools will not be available"

# Pre-install patchright and download Chromium browser
# NOTE: patchright version must match the version pinned in pyproject.toml
RUN pip3 install patchright==1.57.2 && patchright install chromium

RUN PATCHRIGHT_CHROME=$(python3 -c "\
from patchright.sync_api import sync_playwright; \
pw = sync_playwright().start(); \
print(pw.chromium.executable_path); \
pw.stop()") && \
    echo "Detected Chrome path: $PATCHRIGHT_CHROME" && \
    ln -sf "$PATCHRIGHT_CHROME" /usr/local/bin/chromium-patchright && \
    chmod +x /usr/local/bin/chromium-patchright

ENV AGENT_BROWSER_EXECUTABLE_PATH=/usr/local/bin/chromium-patchright

ENV EXECUTABLE_PATH=/usr/local/bin/chromium-patchright